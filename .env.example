# Component A (FastAPI)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=component_a
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/component_a

# Spotify OAuth (optional if only using local auth endpoints)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
REDIRECT_URI=http://127.0.0.1:8000/auth/callback

# App JWT auth
JWT_SECRET_KEY=change-this-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
LOCAL_AUTH_DEFAULT_AGE=18
FRONTEND_APP_URL=http://localhost:5173
INTERNAL_SERVICE_TOKEN=

# Optional encryption key for secure storage features
ENCRYPTION_KEY=

# Component B (Music Service)
COUCHDB_USER=admin
COUCHDB_PASSWORD=secret

# RabbitMQ / Eventing
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
RABBITMQ_EVENTS_EXCHANGE=fitbeat.events
RABBITMQ_DLX_EXCHANGE=fitbeat.events.dlx
EVENT_QUEUE_NAME=fitbeat.event-processor.q
EVENT_DLQ_NAME=fitbeat.event-processor.dlq
WEEKLY_SESSIONS_GOAL=3

# Component D (Achievements Service RabbitMQ contract)
ACHIEVEMENTS_QUEUE_NAME=fitbeat.achievements.q
ACHIEVEMENTS_RETRY_QUEUE_NAME=fitbeat.achievements.retry.q
ACHIEVEMENTS_DLQ_NAME=fitbeat.achievements.dlq
ACHIEVEMENTS_RETRY_ROUTING_KEY=fitbeat.achievements.retry
ACHIEVEMENTS_DLQ_ROUTING_KEY=fitbeat.achievements.dlq
ACHIEVEMENTS_MAX_RETRIES=3
ACHIEVEMENTS_RETRY_DELAY_MS=5000
ACHIEVEMENTS_DEFAULT_SESSION_MINUTES=30

# Component C (Event Processor DB)
EVENT_DB_NAME=event_processor
EVENT_DB_USER=postgres
EVENT_DB_PASSWORD=postgres

# Component D (Achievements Service - PostgreSQL)
ACH_POSTGRES_USER=postgres
ACH_POSTGRES_PASSWORD=postgres
ACH_POSTGRES_DB=achievements_db

# Fallback SQLite (solo local opcional)
ACHIEVEMENTS_DB_PATH=/app/Data/achievements.db

# Component E (Notification Service DB)
NOTIFICATION_DB_NAME=notification_service
NOTIFICATION_DB_USER=postgres
NOTIFICATION_DB_PASSWORD=postgres

# Component F (Notification Service)
NOTIFICATION_QUEUE_NAME=fitbeat.notification.q
NOTIFICATION_RETRY_QUEUE_NAME=fitbeat.notification.retry.q
NOTIFICATION_DLQ_NAME=fitbeat.notification.dlq
NOTIFICATION_DLX_NAME=fitbeat.notification.dlx
NOTIFICATION_MAX_RETRIES=3
NOTIFICATION_RETRY_DELAY_MS=5000
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=fitbeat1e@gmail.com
SMTP_PASS=mail-password

# ===================================================================
# Horizontal Scaling Configuration
# ===================================================================
# Instance identification for monitoring and debugging
# These are automatically set in docker-compose.yml for each replica
# INSTANCE_ID values: user-service-1, user-service-2, user-service-3, etc.

# Load Balancing Strategy (KrakenD default: round-robin)
# Available strategies: round_robin, random, sequential
# Note: KrakenD Community Edition uses round-robin by default

# Service Replicas Configuration
# User Service: 3 replicas (component_a_1, component_a_2, component_a_3)
# Music Service: 3 replicas (music_service_1, music_service_2, music_service_3)
# Achievements Service: 3 replicas (achievements_service_1, achievements_service_2, achievements_service_3)
# Notification Service: 3 replicas (notification_service_1, notification_service_2, notification_service_3)
# Event Processor: 2 replicas (event_processor_1, event_processor_2)

# Database Connection Pooling (adjust based on number of replicas)
# Recommended: pool_size=5 per replica, max_overflow=10
# Example: postgresql://user:pass@db:5432/dbname?pool_size=5&max_overflow=10

